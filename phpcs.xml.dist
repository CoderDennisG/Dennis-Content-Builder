<?xml version="1.0"?>
<ruleset name="Dennis Content Builder">
	<description>WPCS for the plugin. Pragmatic exclusions are documented inline.</description>

	<file>dennis-content-builder.php</file>
	<file>uninstall.php</file>
	<file>includes</file>

	<arg value="sp"/>
	<arg name="extensions" value="php"/>
	<arg name="parallel" value="8"/>

	<config name="minimum_wp_version" value="6.6"/>

	<rule ref="WordPress-Core">
		<!-- PSR-4 autoloading: DCB\Admin\Settings lives in Settings.php, not class-settings.php. -->
		<exclude name="WordPress.Files.FileName"/>
		<!-- declare(strict_types=1) sits on the open tag line by PSR convention. -->
		<exclude name="Squiz.Commenting.FileComment.Missing"/>
		<exclude name="PSR2.Files.ClosingTag"/>
		<!-- The Anthropic SDK exposes camelCase object properties; reads can't be renamed. -->
		<exclude name="WordPress.NamingConventions.ValidVariableName.UsedPropertyNotSnakeCase"/>
	</rule>

	<rule ref="WordPress.Security"/>
	<rule ref="WordPress.DB"/>

	<!-- Translator comments + escaping are load-bearing; keep them errors. -->
	<rule ref="WordPress.Security.EscapeOutput"/>
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="dennis-content-builder"/>
			</property>
		</properties>
	</rule>
</ruleset>
